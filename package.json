{
  "scripts": {
    "build": "tsc && node dist/build/build.js",
    "postinstall": "[ -n \"$CI\" ] || node node_modules/@codyswann/lisa/dist/index.js --yes --skip-git-check . 2>/dev/null || true",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "seed": "bun run build && node dist/scripts/seed.js",
    "verify": "bun run build && node dist/scripts/verify.js",
    "dev:server": "bun run build && node dist/scripts/dev_server.js",
    "deploy": "bun run build && node dist/scripts/deploy.js",
    "test:e2e": "bash scripts/e2e-local-harper.sh",
    "bootstrap": "bash scripts/bootstrap.sh",
    "setup:deploy-key": "setup-deploy-key",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "start": "harperdb start",
    "stop": "harperdb stop",
    "status": "harperdb status",
    "reset": "harperdb stop || true; [ -n \"$HOME\" ] && rm -rf \"$HOME/.harperdb\" && bun run bootstrap && bun run seed && bun run verify",
    "lint": "oxlint && eslint . --quiet",
    "format:check": "prettier --check .",
    "format": "prettier --check . --write",
    "test:setup:playwright": "bunx playwright install chromium",
    "test:watch": "vitest",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "lint:slow": "eslint . --config eslint.slow.config.ts --quiet",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "sg:scan": "ast-grep scan",
    "prepare": "husky install || true",
    "test:unit": "vitest run --exclude='**/integration/**'"
  },
  "engines": {
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "pnpm": "please-use-bun",
    "bun": ">= 1.3.11",
    "node": ">= 22.21.1"
  },
  "name": "your-project",
  "version": "0.0.2",
  "description": "Harper Fabric application starter.",
  "private": true,
  "type": "module",
  "dependencies": {
    "harperdb": "^4.7.29"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.40.4",
    "@codyswann/lisa": "^2.176.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-oxlint": "^1.62.0",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "husky": "^8.0.0",
    "jiti": "^2.4.0",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "playwright": "^1.56.1",
    "prettier": "^3.3.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "uuid": "^13.0.0",
    "vitest": "^4.1.0"
  },
  "resolutions": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.2",
    "handlebars": ">=4.7.9",
    "ws": ">=8.21.0",
    "esbuild": ">=0.28.1",
    "lodash": ">=4.18.1",
    "vite": ">=8.0.16",
    "form-data": ">=4.0.6"
  },
  "overrides": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.2",
    "handlebars": ">=4.7.9",
    "ws": ">=8.21.0",
    "esbuild": ">=0.28.1",
    "lodash": ">=4.18.1",
    "vite": "^8.0.16",
    "form-data": ">=4.0.6"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@codyswann/lisa",
    "@sentry/cli"
  ],
  "packageManager": "bun@1.3.11"
}
